# vim: set filetype=gitconfig : ~
# vim: set shiftwidth=4 : ~
# vim: set softtabstop=0 : ~
# vim: set noexpandtab : ~

# https://stackoverflow.com/questions/32186600#comment52260296_32186600

[advice]
	pushNonFastForward = false
	skippedCherryPicks = false
	refSyntax = false
	ignoredHook = false

[apply]
	whitespace = fix

[branch]
	autosetupmerge = true

[commit]
	template = ~/.config/git/commit-message-template
	verbose = true

[core]
	editor = nvim

	# http://stackoverflow.com/a/11262153
	# use `$GIT_DIR/info/exclude` file to ignore per project stuff silently
	excludesfile = ~/.config/git/global-ignore

	# http://goo.gl/Vug01E
	autocrlf = input
	safecrlf = true
	whitespace = space-before-tab,-blank-at-eof
	filemode = false

[diff]
	tool = nvimdiff
	renameLimit = 0
	renames = copies
	mnemonicprefix = true
	algorithm = patience
	wsErrorHighlight = all
	# does not show any source or destination prefix (`a/` / `b/` as default)
	noprefix = true

[difftool]
	prompt = false

[difftool "nvimdiff"]
	cmd = nvim -f -d -c 'wincmd l' -c 'cd "$GIT_PREFIX"' "$LOCAL" "$REMOTE"

[fetch]
	prune = true

[init]
	defaultBranch = main
	templatedir = ~/.config/git/templates

[log]
	abbrevCommit = true
	date = local

[merge]
	conflictstyle = merge
	renameLimit = 0
	stat = true
	tool = nvimdiff

[mergetool]
	prompt = false
	keepBackup = false

[pull]
	ff = only

[push]
	default = current
	followTags = true
	autoSetupRemote = true

[rebase]
	autoStash = true

[rerere]
	enabled = true

[user]
    name = "Vasyl Zuziak"

[include]
	path = gituser
	path = aliases
	path = colors
	path = maintenance
	path = user-options
	path = lfs

