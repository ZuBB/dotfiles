#!/usr/bin/env bash

set -euo pipefail

CURRENT_BRANCH="$(git branch --show-current)"
COMMIT_TITLE="$(git log -1 --pretty=%s)"
COMMIT_BODY="$(git log -1 --pretty=%b)"

git push --quiet --set-upstream origin "$CURRENT_BRANCH"

PR_MESSAGE_FILE="$(mktemp)"
trap 'rm -f "$PR_MESSAGE_FILE"' EXIT

PR_BODY_ARGS=(--body '')

if [ -n "$COMMIT_BODY" ]; then
  printf '%s\n' "$COMMIT_BODY" > "$PR_MESSAGE_FILE"

  JIRA_HOST="${JIRA_HOST:-fallback.jira.net}"
  ISSUE_PATTERN='[A-Z][A-Z0-9]+-[0-9]+'

  if grep -Eq "$ISSUE_PATTERN" "$PR_MESSAGE_FILE"; then
    sed -i '' -E "s#(references )($ISSUE_PATTERN)#\1[\2](https://$JIRA_HOST/browse/\2)#g" "$PR_MESSAGE_FILE"
  fi

  PR_BODY_ARGS=(--body-file "$PR_MESSAGE_FILE")
fi

PR_OUTPUT="$(
  gh pr create \
    --head "$CURRENT_BRANCH" \
    -t "$COMMIT_TITLE" \
    "${PR_BODY_ARGS[@]}"
)"

PR_URL="$(printf '%s\n' "$PR_OUTPUT" | grep -o 'https://[^ ]*' | head -n 1)"

if [ -z "$PR_URL" ]; then
  echo "Error: PR was not created or PR URL was not found."
  echo "$PR_OUTPUT"
  exit 1
fi

if [[ "$OSTYPE" == "darwin"* ]]; then
  open "$PR_URL"
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
  xdg-open "$PR_URL"
else
  echo "Unsupported OS. Please open the URL manually:"
fi

echo -e "The following PR was created:\n$PR_URL\n"
